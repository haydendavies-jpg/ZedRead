# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zedread:zedread@localhost:5432/zedread
TEST_DATABASE_URL=postgresql+asyncpg://test:test@localhost:5433/zedread_test

# ── Environment ───────────────────────────────────────────────────────────────
# "production" (or any value not in development/dev/local/test/testing) makes the
# app refuse to start unless SECRET_KEY is a strong, non-placeholder 32+ char key.
ENVIRONMENT=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters and NOT the placeholder below when ENVIRONMENT
# is production — startup fails otherwise. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
# "json" for production (Grafana Loki), anything else for coloured dev output
LOG_FORMAT=dev

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=ZedRead POS <onboarding@resend.dev>
INVITE_BASE_URL=http://localhost:5173
INVITE_EXPIRY_HOURS=72
PORTAL_BASE_URL=http://localhost:5173
PASSWORD_RESET_EXPIRY_HOURS=1

# ── Supabase Storage (added in Stage 8) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_STORAGE_KEY=your-service-role-key
